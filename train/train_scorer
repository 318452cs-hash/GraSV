#!/usr/bin/env python3
"""Train a GraSV-compatible CNN scorer from prepared candidate labels.

This is a lightweight, portable training entry point for the public GitHub
release. It expects candidate features exported by ``grasv infer`` and labels
from Truvari output directories. The saved checkpoint is compatible with
``grasv infer --cluster-scorer-path`` and has ``model_type=cnn_scorer_v1``.
"""

from __future__ import annotations

import argparse
import csv
import json
import os
import sys
from collections import Counter
from pathlib import Path
from typing import Any, Dict, Iterable, List, Sequence, Tuple

import numpy as np
import torch
from torch.utils.data import DataLoader, TensorDataset


def _repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


ROOT = _repo_root()
SRC = ROOT / "src"
if str(SRC) not in sys.path:
    sys.path.insert(0, str(SRC))

from grasv.scorer import CandidateCNNScorer, GRASV_SCORER_FEATURE_NAMES, vectorize_record_features  # noqa: E402
from grasv.signature_features import load_call_features  # noqa: E402
from grasv.utils import get_device  # noqa: E402


def _read_vcf_ids(path: Path) -> set[str]:
    ids: set[str] = set()
    if not path.exists():
        return ids
    with path.open("r", encoding="utf-8", errors="replace") as handle:
        for line in handle:
            if not line or line.startswith("#"):
                continue
            fields = line.rstrip("\n").split("\t")
            if len(fields) >= 3 and fields[2] and fields[2] != ".":
                ids.add(fields[2])
    return ids


def load_truvari_filter_labels(truvari_dir: str | Path) -> Tuple[set[str], set[str]]:
    """Return TP-call IDs and FP IDs from a Truvari output directory."""
    root = Path(truvari_dir)
    tp_ids = _read_vcf_ids(root / "tp-call.vcf")
    fp_ids = _read_vcf_ids(root / "fp.vcf")
    if not tp_ids and not fp_ids:
        raise ValueError(f"No tp-call.vcf/fp.vcf labels found in {root}")
    return tp_ids, fp_ids


def _read_manifest(path: str | None) -> List[Dict[str, Any]]:
    if not path:
        return []
    manifest_path = Path(path)
    if manifest_path.suffix.lower() == ".json":
        payload = json.loads(manifest_path.read_text(encoding="utf-8"))
        if isinstance(payload, dict):
            payload = payload.get("runs", payload.get("records", []))
        if not isinstance(payload, list):
            raise ValueError("JSON manifest must be a list or contain a 'runs' list.")
        return [dict(item) for item in payload]

    delimiter = "\t" if manifest_path.suffix.lower() in {".tsv", ".tab"} else ","
    with manifest_path.open("r", encoding="utf-8", newline="") as handle:
        return [dict(row) for row in csv.DictReader(handle, delimiter=delimiter)]


def _direct_records(args: argparse.Namespace) -> List[Dict[str, Any]]:
    rows: List[Dict[str, Any]] = []
    if args.train_call_features and args.train_truvari_dir:
        rows.append(
            {
                "split": "train",
                "call_features": args.train_call_features,
                "truvari_dir": args.train_truvari_dir,
                "domain": args.domain,
                "platform": args.platform,
            }
        )
    if args.validation_call_features and args.validation_truvari_dir:
        rows.append(
            {
                "split": "validation",
                "call_features": args.validation_call_features,
                "truvari_dir": args.validation_truvari_dir,
                "domain": args.domain,
                "platform": args.platform,
            }
        )
    if args.test_call_features and args.test_truvari_dir:
        rows.append(
            {
                "split": "test",
                "call_features": args.test_call_features,
                "truvari_dir": args.test_truvari_dir,
                "domain": args.domain,
                "platform": args.platform,
            }
        )
    return rows


def _annotate_records(records: Sequence[Dict[str, Any]], row: Dict[str, Any]) -> List[Dict[str, Any]]:
    domain = str(row.get("domain", "") or "").strip().lower()
    platform = str(row.get("platform", "") or "").strip().lower()
    dataset = str(row.get("dataset", row.get("name", "")) or "").strip()
    annotated: List[Dict[str, Any]] = []
    for record in records:
        updated = dict(record)
        if domain:
            updated["domain"] = domain
        if platform:
            updated["platform"] = platform
        if dataset:
            updated["dataset_name"] = dataset
        annotated.append(updated)
    return annotated


def _collect_labeled_records(
    rows: Sequence[Dict[str, Any]],
    split: str,
    feature_names: Sequence[str],
) -> Tuple[np.ndarray, np.ndarray, Dict[str, Any]]:
    X_values: List[np.ndarray] = []
    y_values: List[int] = []
    used_rows = 0
    label_counts: Counter[int] = Counter()

    for row in rows:
        row_split = str(row.get("split", "train") or "train").lower()
        if row_split != split:
            continue
        call_features = row.get("call_features") or row.get("call_features_path")
        truvari_dir = row.get("truvari_dir") or row.get("truvari")
        if not call_features or not truvari_dir:
            raise ValueError(f"Manifest row for split={split} needs call_features and truvari_dir: {row}")

        records = _annotate_records(load_call_features(str(call_features)), row)
        tp_ids, fp_ids = load_truvari_filter_labels(truvari_dir)
        used_rows += 1
        for record in records:
            call_id = str(record.get("call_id", "") or "")
            if call_id in tp_ids:
                X_values.append(vectorize_record_features(record, feature_names=feature_names))
                y_values.append(1)
                label_counts[1] += 1
            elif call_id in fp_ids:
                X_values.append(vectorize_record_features(record, feature_names=feature_names))
                y_values.append(0)
                label_counts[0] += 1

    if not X_values:
        raise ValueError(f"No labeled records collected for split={split}.")
    if len(set(y_values)) < 2:
        raise ValueError(f"Split {split} needs both TP and FP labels.")

    return (
        np.asarray(X_values, dtype=np.float32),
        np.asarray(y_values, dtype=np.int64),
        {"rows": used_rows, "label_counts": dict(label_counts), "n_samples": len(y_values)},
    )


def _normalize_features(X: np.ndarray) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    mean = X.mean(axis=0).astype(np.float32)
    scale = X.std(axis=0).astype(np.float32)
    scale[scale < 1e-6] = 1.0
    return ((X - mean) / scale).astype(np.float32), mean, scale


def _apply_normalization(X: np.ndarray, mean: np.ndarray, scale: np.ndarray) -> np.ndarray:
    return ((X - mean) / np.clip(scale, 1e-6, None)).astype(np.float32)


def _binary_metrics(y_true: np.ndarray, probs: np.ndarray, threshold: float) -> Dict[str, Any]:
    pred = (probs >= float(threshold)).astype(np.int64)
    tp = int(np.sum((y_true == 1) & (pred == 1)))
    fp = int(np.sum((y_true == 0) & (pred == 1)))
    fn = int(np.sum((y_true == 1) & (pred == 0)))
    precision = tp / max(1, tp + fp)
    recall = tp / max(1, tp + fn)
    f1 = 0.0 if precision + recall == 0.0 else 2.0 * precision * recall / (precision + recall)
    return {"tp": tp, "fp": fp, "fn": fn, "precision": precision, "recall": recall, "f1": f1}


def _select_threshold(y_true: np.ndarray, probs: np.ndarray) -> Tuple[float, Dict[str, Any]]:
    best_threshold = 0.5
    best_metrics = {"f1": -1.0, "precision": 0.0, "recall": 0.0, "tp": 0, "fp": 0, "fn": 0}
    for threshold in np.linspace(0.05, 0.95, 91):
        metrics = _binary_metrics(y_true, probs, float(threshold))
        if (
            metrics["f1"] > best_metrics["f1"]
            or (metrics["f1"] == best_metrics["f1"] and metrics["precision"] > best_metrics["precision"])
            or (
                metrics["f1"] == best_metrics["f1"]
                and metrics["precision"] == best_metrics["precision"]
                and metrics["recall"] > best_metrics["recall"]
            )
        ):
            best_threshold = float(threshold)
            best_metrics = metrics
    return best_threshold, best_metrics


def _predict_probs(model: CandidateCNNScorer, X: np.ndarray, batch_size: int, device: torch.device) -> np.ndarray:
    loader = DataLoader(TensorDataset(torch.from_numpy(X.astype(np.float32))), batch_size=batch_size, shuffle=False)
    chunks: List[np.ndarray] = []
    model.eval()
    with torch.no_grad():
        for (batch_x,) in loader:
            logits = model(batch_x.to(device))
            chunks.append(torch.sigmoid(logits).cpu().numpy().astype(np.float32))
    return np.concatenate(chunks, axis=0) if chunks else np.zeros((0,), dtype=np.float32)


def _train_model(
    X: np.ndarray,
    y: np.ndarray,
    args: argparse.Namespace,
) -> Tuple[CandidateCNNScorer, List[Dict[str, float]]]:
    device = get_device()
    model = CandidateCNNScorer(
        feature_dim=X.shape[1],
        channels=tuple(int(v) for v in args.channels),
        hidden_dim=int(args.hidden_dim),
        dropout=float(args.dropout),
    ).to(device)
    y_float = y.astype(np.float32)
    pos = float(np.sum(y_float == 1.0))
    neg = float(np.sum(y_float == 0.0))
    pos_weight = torch.tensor([neg / max(1.0, pos)], dtype=torch.float32, device=device)
    criterion = torch.nn.BCEWithLogitsLoss(pos_weight=pos_weight)
    optimizer = torch.optim.Adam(model.parameters(), lr=float(args.lr), weight_decay=float(args.weight_decay))

    dataset = TensorDataset(torch.from_numpy(X), torch.from_numpy(y_float))
    loader = DataLoader(dataset, batch_size=int(args.batch_size), shuffle=True)
    history: List[Dict[str, float]] = []
    for epoch in range(1, int(args.epochs) + 1):
        model.train()
        losses: List[float] = []
        for batch_x, batch_y in loader:
            batch_x = batch_x.to(device)
            batch_y = batch_y.to(device)
            optimizer.zero_grad(set_to_none=True)
            loss = criterion(model(batch_x), batch_y)
            loss.backward()
            optimizer.step()
            losses.append(float(loss.item()))
        history.append({"epoch": float(epoch), "loss": float(np.mean(losses)) if losses else 0.0})
        print(f"epoch={epoch} loss={history[-1]['loss']:.6f}", flush=True)
    return model, history


def _write_json(path: str | None, payload: Dict[str, Any]) -> None:
    if not path:
        return
    output = Path(path)
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(json.dumps(payload, ensure_ascii=True, indent=2, sort_keys=True), encoding="utf-8")


def build_arg_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Train a GraSV cnn_scorer_v1 checkpoint.")
    parser.add_argument("--manifest", default=None, help="Optional CSV/TSV/JSON manifest with split,call_features,truvari_dir.")
    parser.add_argument("--train-call-features", "--train_call_features", dest="train_call_features", default=None)
    parser.add_argument("--train-truvari-dir", "--train_truvari_dir", dest="train_truvari_dir", default=None)
    parser.add_argument("--validation-call-features", "--validation_call_features", dest="validation_call_features", default=None)
    parser.add_argument("--validation-truvari-dir", "--validation_truvari_dir", dest="validation_truvari_dir", default=None)
    parser.add_argument("--test-call-features", "--test_call_features", dest="test_call_features", default=None)
    parser.add_argument("--test-truvari-dir", "--test_truvari_dir", dest="test_truvari_dir", default=None)
    parser.add_argument("--platform", default="")
    parser.add_argument("--domain", default="real", choices=["real", "sim", ""])
    parser.add_argument("--output-path", "--output_path", dest="output_path", required=True)
    parser.add_argument("--summary-path", "--summary_path", dest="summary_path", default=None)
    parser.add_argument("--epochs", type=int, default=30)
    parser.add_argument("--batch-size", "--batch_size", dest="batch_size", type=int, default=1024)
    parser.add_argument("--lr", type=float, default=1e-3)
    parser.add_argument("--weight-decay", "--weight_decay", dest="weight_decay", type=float, default=1e-4)
    parser.add_argument("--dropout", type=float, default=0.1)
    parser.add_argument("--channels", type=int, nargs=3, default=(32, 64, 64))
    parser.add_argument("--hidden-dim", "--hidden_dim", dest="hidden_dim", type=int, default=64)
    parser.add_argument("--torch-num-threads", "--torch_num_threads", dest="torch_num_threads", type=int, default=8)
    return parser


def main(argv: List[str] | None = None) -> int:
    args = build_arg_parser().parse_args(argv)
    torch.set_num_threads(max(1, int(args.torch_num_threads)))

    rows = _read_manifest(args.manifest) + _direct_records(args)
    if not rows:
        raise SystemExit("Provide --manifest or --train-call-features plus --train-truvari-dir.")

    feature_names = tuple(GRASV_SCORER_FEATURE_NAMES)
    X_train_raw, y_train, train_info = _collect_labeled_records(rows, "train", feature_names)
    X_train, mean, scale = _normalize_features(X_train_raw)

    validation_available = any(str(row.get("split", "")).lower() == "validation" for row in rows)
    test_available = any(str(row.get("split", "")).lower() == "test" for row in rows)

    model, loss_history = _train_model(X_train, y_train, args)
    device = get_device()
    train_probs = _predict_probs(model, X_train, int(args.batch_size), device)

    eval_payload: Dict[str, Any] = {}
    if validation_available:
        X_val_raw, y_val, val_info = _collect_labeled_records(rows, "validation", feature_names)
        X_val = _apply_normalization(X_val_raw, mean, scale)
        val_probs = _predict_probs(model, X_val, int(args.batch_size), device)
        threshold, threshold_metrics = _select_threshold(y_val, val_probs)
        eval_payload["validation"] = {
            **val_info,
            "metrics": _binary_metrics(y_val, val_probs, threshold),
        }
        threshold_split = "validation"
    else:
        threshold, threshold_metrics = _select_threshold(y_train, train_probs)
        threshold_split = "train"

    eval_payload["train"] = {
        **train_info,
        "metrics": _binary_metrics(y_train, train_probs, threshold),
    }

    if test_available:
        X_test_raw, y_test, test_info = _collect_labeled_records(rows, "test", feature_names)
        X_test = _apply_normalization(X_test_raw, mean, scale)
        test_probs = _predict_probs(model, X_test, int(args.batch_size), device)
        eval_payload["test"] = {
            **test_info,
            "metrics": _binary_metrics(y_test, test_probs, threshold),
        }

    payload = {
        "model_type": "cnn_scorer_v1",
        "feature_names": list(feature_names),
        "mean": mean.tolist(),
        "scale": scale.tolist(),
        "threshold": float(threshold),
        "threshold_selection_metrics": threshold_metrics,
        "threshold_selection_split": threshold_split,
        "train_metrics": eval_payload["train"]["metrics"],
        "label_counts": dict(Counter(int(v) for v in y_train.tolist())),
        "n_samples": int(len(y_train)),
        "epochs": int(args.epochs),
        "batch_size": int(args.batch_size),
        "learning_rate": float(args.lr),
        "weight_decay": float(args.weight_decay),
        "dropout": float(args.dropout),
        "model_config": {
            "feature_dim": int(X_train.shape[1]),
            "channels": [int(v) for v in args.channels],
            "hidden_dim": int(args.hidden_dim),
            "dropout": float(args.dropout),
        },
        "loss_history": loss_history,
        "state_dict": {key: value.detach().cpu() for key, value in model.state_dict().items()},
    }

    output_path = Path(args.output_path)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    torch.save(payload, output_path)

    summary = {
        "output_path": str(output_path),
        "feature_names": list(feature_names),
        "threshold": float(threshold),
        "threshold_selection_metrics": threshold_metrics,
        "threshold_selection_split": threshold_split,
        "loss_history": loss_history,
        "evaluation": eval_payload,
        "manifest_rows": rows,
    }
    _write_json(args.summary_path, summary)
    print(f"model={output_path}")
    if args.summary_path:
        print(f"summary={args.summary_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
